rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3 Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.email == request.auth.token.email &&
             data.role in ['user', 'admin'] &&
             data.role == 'user' && 
             data.createdAt == request.time;
    }

    function isValidCase(data) {
      return data.keys().hasAll(['userId', 'animalType', 'symptoms', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.animalType is string && data.animalType.size() <= 50 &&
             data.symptoms is string && data.symptoms.size() <= 5000 &&
             data.createdAt == request.time;
    }

    function isValidVaccine(data) {
      return data.keys().hasAll(['userId', 'animalName', 'vaccineType', 'dueDate', 'administered']) &&
             data.userId == request.auth.uid &&
             data.animalName is string && data.animalName.size() <= 100 &&
             data.vaccineType is string && data.vaccineType.size() <= 100 &&
             data.administered is bool;
    }

    function isValidDietPlan(data) {
      return data.keys().hasAll(['animalType', 'planName', 'description', 'nutritionalInfo']) &&
             data.animalType is string && data.animalType.size() <= 50 &&
             data.planName is string && data.planName.size() <= 100;
    }

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isValidId(userId) && isOwner(userId);
      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name']) &&
                      incoming().name is string && incoming().name.size() <= 100;
    }

    // 2. Cases
    match /cases/{caseId} {
      allow get: if isValidId(caseId) && isVerified() && existing().userId == request.auth.uid;
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(caseId) && isVerified() && isValidCase(incoming());
      allow delete: if isValidId(caseId) && isVerified() && existing().userId == request.auth.uid;
    }

    // 3. Vet Locations
    match /vet_locations/{vetId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }

    // 4. Vaccines
    match /vaccines/{vaccineId} {
      allow get: if isValidId(vaccineId) && isVerified() && existing().userId == request.auth.uid;
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(vaccineId) && isVerified() && isValidVaccine(incoming());
      allow update: if isValidId(vaccineId) && isVerified() && existing().userId == request.auth.uid && 
                       isValidVaccine(incoming());
      allow delete: if isValidId(vaccineId) && isVerified() && existing().userId == request.auth.uid;
    }

    // 5. Diet Plans
    match /diet_plans/{planId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }
    
    // 6. Admin Bootstrap
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
